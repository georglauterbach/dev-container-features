{
  "id": "lang-rust",
  "version": "0.5.0",
  "name": "Programming Language | Rust",
  "documentationURL": "https://github.com/georglauterbach/dev-container-features/tree/main/src/lang-rust",
  "description": "This Feature provides language support for Rust.",
  "options": {
    "generate-shell-completions": {
      "description": "Whether to generate shell completion for Rustup and Cargo",
      "type": "boolean",
      "default": true
    },
    "rustup-disable-auto-self-update": {
      "description": "Whether to disable Rustup's self-update feature",
      "type": "boolean",
      "default": true
    }
  },
  "containerEnv": {
    // Directory that contains common configuration files and more for this Feature
    "DCF_LANG_RUST_DIR": "/usr/local/share/dev_containers/features/ghcr_io/georglauterbach/lang_rust"
  },
  "onCreateCommand": "{ command -v rustup >/dev/null 2>/dev/null && test -f \"${DCF_LANG_RUST_DIR}/.rustup_disable_auto_self_update\" && rustup set auto-self-update disable ; } || :",
  "customizations": {
    "vscode": {
      "extensions": [
        // Rust language server
        //
        // REF https://rust-analyzer.github.io/
        //     https://en.wikipedia.org/wiki/Language_Server_Protocol
        "rust-lang.rust-analyzer",
        // TOML language server
        //
        // REF https://github.com/tombi-toml/tombi
        //     https://en.wikipedia.org/wiki/Language_Server_Protocol
        "tombi-toml.tombi",
        // LLVM-based debugger
        //
        // LLDB is newer than GDB and provides improved performance.
        // Since Rust uses LLVM, LLDB is a natural fit.
        //
        // REF https://github.com/vadimcn/codelldb
        //     https://lldb.llvm.org/
        "vadimcn.vscode-lldb@1.12.2"
      ],
      "settings": {
        // mark the directory for build-artifacts as read-only
        // and apply the same in the subdirectory `code/`
        "files.readonlyInclude": {
          "target": true,
          "code/target": true
        },
        // exclude the directory for build-artifacts from the
        // VS explorer watcher and apply the same in the
        // subdirectory `code/`
        "files.watcherExclude": {
          "target": true,
          "code/target": true
        },
        // rust-lang.rust-analyzer
        //   - prefer Self in `match` completions
        "rust-analyzer.assist.preferSelf": true,
        //   - instruct rust-analyzer to use a different
        //     path for its target directory to not lock
        //     Cargo.lock, i.e. to make building and
        //     analyzing the code work in parallel
        "rust-analyzer.cargo.targetDir": true,
        //   - use clippy when running diagnostics
        "rust-analyzer.check.command": "clippy",
        //   - run diagnostics on save
        "rust-analyzer.checkOnSave": true,
        //   - disable diagnostics while typing
        "rust-analyzer.diagnostics.enable": false,
        //   - enable stylistic lists
        "rust-analyzer.diagnostics.styleLints.enable": true,
        //   - use rustc error codes
        "rust-analyzer.diagnostics.useRustcErrorCode": true,
        //   - restart the language server
        //     when its configuration was changed
        "rust-analyzer.restartServerOnConfigChange": true,
        //   - enable the test explorer integration
        "rust-analyzer.testExplorer": true,
        // vadimcn.vscode-lldb
        //   - tell LLDB that we debug Rust
        "lldb.launch.sourceLanguages": [
          "rust"
        ]
      }
    }
  },
  // enable proper debugging by allowing
  // the debuggee to be `ptrace`d
  "capAdd": [
    "SYS_PTRACE"
  ]
}
