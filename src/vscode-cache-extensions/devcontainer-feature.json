{
  "id": "vscode-cache-extensions",
  "version": "0.3.0",
  "name": "VS Code | Cache Extensions",
  "documentationURL": "https://github.com/georglauterbach/dev-container-features/tree/main/src/vscode-cache-extensions",
  "description": "This Feature prevents superfluous (re-)installations of VS Code extensions upon container restarts.",
  "containerEnv": {
    // denotes the directory to which a volume is mounted to persist extensions
    "DCF_VSCODE_CACHE_EXTENSIONS_DIR": "/usr/local/share/dev_containers/features/ghcr_io/georglauterbach/vscode_cache_extensions"
  },
  "mounts": [
    {
      // the volume in which extensions are persisted
      "source": "dev_containers.features.ghcr_io.georglauterbach.vscode_cache_extensions.${devcontainerId}",
      "target": "/usr/local/share/dev_containers/features/ghcr_io/georglauterbach/vscode_cache_extensions",
      "type": "volume"
    }
  ]
}
